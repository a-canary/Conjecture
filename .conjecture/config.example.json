{
  "providers": [
    {
      "url": "https://openrouter.ai/api/v1",
      "api": "",
      "model": "deepseek/deepseek-chat",
      "name": "openrouter",
      "priority": 1,
      "is_local": false,
      "env_var": "OPENROUTER_API_KEY",
      "description": "Primary: DeepSeek via OpenRouter",
      "max_tokens": 64000,
      "temperature": 0.2,
      "timeout": 60,
      "max_retries": 3
    },
    {
      "url": "https://api.chutes.ai/v1",
      "api": "",
      "model": "deepseek-ai/DeepSeek-V3-0324",
      "name": "chutes",
      "priority": 2,
      "is_local": false,
      "env_var": "CHUTES_API_KEY",
      "description": "Fallback: DeepSeek via Chutes",
      "max_tokens": 64000,
      "temperature": 0.2,
      "timeout": 60,
      "max_retries": 3
    },
    {
      "url": "http://localhost:1234/v1",
      "api": "not-needed",
      "model": "lfm-2.5",
      "name": "lm_studio",
      "priority": 3,
      "is_local": true,
      "description": "Local: LFM-2.5 via LM Studio",
      "max_tokens": 8192,
      "temperature": 0.2,
      "timeout": 120,
      "max_retries": 1
    }
  ],
  "confidence_threshold": 0.5,
  "confident_threshold": 0.75,
  "max_context_size": 5,
  "batch_size": 3,
  "debug": false,
  "database_path": "data/conjecture.db",
  "user": "user",
  "team": "default"
}