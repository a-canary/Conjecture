# cron: */30 * * * *
# timeout: 600
# approval: auto
# Heartbeat — invokes Claude CLI with the heartbeat prompt.
# Runs every 30 min. Claude reads HEARTBEAT.md and performs self-checks.

claude --print -p "$(cat /app/heartbeat-prompt.md)" \
  --dangerously-skip-permissions \
  --output-format json \
  --max-turns 30 \
  --model claude-sonnet-4-5-20250929 \
  2>/dev/null | jq -r '.result // empty'
